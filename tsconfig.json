{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "paths": {
      "@utils/*": ["./utils/*"],
      "@pages/*": ["./pages/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
